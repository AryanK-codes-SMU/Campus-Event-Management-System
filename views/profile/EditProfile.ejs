<!DOCTYPE html>
<html lang="en">
<head><title>Edit Profile</title></head>
<body bgcolor="#f0f2f5">

<br><br>
<div align="center">
    <h1>Edit Profile</h1>
    <br>
    <form action="/profile/edit" method="POST">
        <table border="1" cellpadding="10" width="400">
            <tr>
                <th>First Name</th>
                <td><input type="text" name="firstName" value="<%= user.firstName %>" required></td>
            </tr>
            <tr>
                <th>Last Name</th>
                <td><input type="text" name="lastName" value="<%= user.lastName %>" required></td>
            </tr>
            <tr>
                <th>Date of Birth</th>
                <td><input type="date" name="dob" value="<%= user.dob.toISOString().split('T')[0] %>" max="<%= new Date().toISOString().split("T")[0]%>" required></td>
            </tr>
            <tr>
                <th>Email</th>
                <td><%= user.schoolEmail %></td>
            </tr>
            <tr>
                <th>Gender</th>
                <td><select name="gender" required>
                    <option value="">Select Gender</option>
                    <option value="Male" <%= user.gender === "Male" ? "selected" : "" %>>Male</option>
                    <option value="Female" <%= user.gender === "Female" ? "selected" : "" %>>Female</option>
                    </select>
                </td>
            </tr>
        </table>
        <% if (error) { %>
            <p style="color:red;"><%= error %></p>
        <% } %>
        <br>
        <button type="button" onclick="location.href='/DisplayProfile'">← Back to Profile</button>
        <button type="submit">Update</button>
    </form>
</div>

</body>
</html>