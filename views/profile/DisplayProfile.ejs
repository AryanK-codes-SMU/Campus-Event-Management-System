<!DOCTYPE html>
<html lang="en">


<head>
    <title>Display Profile</title>
</head>
<body bgcolor="#f0f2f5">
    <br><br>
    <div align="center">
        <h1>Display Profile</h1>
        <br>
        <table border="1" cellpadding="10" width="400">
            <tr>
                <th>First Name</th><td><%= user.firstName %></td>
            </tr>
            <tr>
                <th>Last Name</th><td><%= user.lastName %></td>
            </tr>
            <tr>
                <th>Date of Birth</th><td><%= user.dob.toLocaleDateString() %></td>
            </tr>
            <tr>
                <th>Email</th><td><%= user.schoolEmail %></td>
            </tr>
            <tr>
                <th>Gender</th><td><%= user.gender %></td>
            </tr>
        </table>
        <br>
        <button onclick="location.href='/events'">← Back to all events</button>
        <button onclick="location.href='/profile/edit'">Edit Profile</button>
    </div>
</body>
</html>